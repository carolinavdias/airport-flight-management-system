# 1. Atualizar .gitignore
cat > .gitignore << 'EOF'
# Binários e objetos
bin/
obj/
*.o
programa-principal
programa-testes

# Resultados gerados
resultados/
resultados-esperados/

# Datasets (TODAS as variações)
dataset/
datasets/
dataset-*/
data-*/
*.csv
!resultados/*.csv

# Ficheiros temporários
*.swp
*.log
*.tmp
*.zip
*_errors.csv

# Backups
backup*/
*.backup
EOF

# 2. Remover dataset do Git (se já estava comitado)
git rm -r --cached dataset/ 2>/dev/null || true
git rm --cached *.csv 2>/dev/null || true

# 3. Remover ficheiros de erro da raiz
rm -f reservations_errors.csv flights_errors.csv

# 4. Verificar que funcionou
git status

# Deve mostrar:
# deleted: dataset/...
# deleted: *.csv